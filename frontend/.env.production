# Frontend Production Environment Variables
# Used during production build

# WebSocket URL for backend connection
# In production, this should match the deployed backend URL
VITE_FRONTEND_WS_URL=ws://localhost:8080

# Disable debug mode in production
VITE_DEBUG_MODE=false

# Shorter timeout for production
VITE_API_TIMEOUT=5000

# Enable metrics for production monitoring
VITE_ENABLE_METRICS=true
