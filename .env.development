# Development Environment Configuration
# Copy this file to .env and adjust values as needed

# Discord Configuration (use test server for development)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=

# LLM Service - Local development server
LLM_SERVER_URL=http://192.168.68.62:1234
LLM_TIMEOUT_MS=10000
LLM_MAX_RETRIES=2
LLM_FALLBACK_ENABLED=true

# Backend - Development settings
BACKEND_HOST=localhost
BACKEND_WS_PORT=8080
AKKA_ACTOR_SYSTEM_NAME=DiscordVisualRoomDev
LOG_LEVEL=DEBUG

# Frontend - Development server
FRONTEND_PORT=8000
FRONTEND_WS_URL=ws://localhost:8080

# Room - Smaller for testing
ROOM_MAX_USERS=10
ROOM_DIMENSIONS_WIDTH=30
ROOM_DIMENSIONS_HEIGHT=10
ROOM_DIMENSIONS_DEPTH=30

# Features - All enabled for development
ENABLE_LLM=true
DEBUG_MODE=true
ENABLE_METRICS=true

# Development optimizations
HOT_RELOAD=true
WS_AUTO_RECONNECT=true
WS_RECONNECT_INTERVAL=1000
