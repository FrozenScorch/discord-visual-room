# Test Environment Configuration
# Used for automated testing and CI/CD

# Discord Configuration (use test bot)
DISCORD_BOT_TOKEN=test_bot_token
DISCORD_GUILD_ID=test_guild_id
DISCORD_VOICE_CHANNEL_ID=test_channel_id

# LLM Service - Mock for testing
LLM_SERVER_URL=http://localhost:9999
LLM_TIMEOUT_MS=1000
LLM_MAX_RETRIES=0
LLM_FALLBACK_ENABLED=true

# Backend - Test configuration
BACKEND_HOST=localhost
BACKEND_WS_PORT=18080
AKKA_ACTOR_SYSTEM_NAME=DiscordVisualRoomTest
LOG_LEVEL=ERROR

# Frontend - Test server
FRONTEND_PORT=18000
FRONTEND_WS_URL=ws://localhost:18080

# Room - Minimal for testing
ROOM_MAX_USERS=4
ROOM_DIMENSIONS_WIDTH=20
ROOM_DIMENSIONS_HEIGHT=10
ROOM_DIMENSIONS_DEPTH=20

# Features - Test configuration
ENABLE_LLM=false
DEBUG_MODE=false
ENABLE_METRICS=false

# Test stability
HOT_RELOAD=false
WS_AUTO_RECONNECT=false
WS_RECONNECT_INTERVAL=500
