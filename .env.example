# Discord Configuration
# Get your bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_VOICE_CHANNEL_ID=your_voice_channel_id_here

# LLM Service Configuration
# Local llama.cpp server URL
LLM_SERVER_URL=http://192.168.68.62:1234
# Timeout in milliseconds for LLM requests
LLM_TIMEOUT_MS=5000
# Maximum number of retry attempts for failed LLM requests
LLM_MAX_RETRIES=1
# Enable LLM fallback to linear layout on failure
LLM_FALLBACK_ENABLED=true

# Backend Configuration
# Host for WebSocket server (0.0.0.0 for all interfaces)
BACKEND_HOST=0.0.0.0
# WebSocket port for client connections
BACKEND_WS_PORT=8080
# Akka actor system configuration
AKKA_ACTOR_SYSTEM_NAME=DiscordVisualRoom
# Log level (ERROR, WARNING, INFO, DEBUG)
LOG_LEVEL=INFO

# Frontend Configuration
# Port for development server
FRONTEND_PORT=8000
# WebSocket URL for frontend to connect (auto-detected in most cases)
FRONTEND_WS_URL=ws://localhost:8080

# Room Configuration
# Maximum number of users allowed in the room
ROOM_MAX_USERS=20
# Room dimensions in 3D space
ROOM_DIMENSIONS_WIDTH=50
ROOM_DIMENSIONS_HEIGHT=10
ROOM_DIMENSIONS_DEPTH=50

# Feature Flags
# Enable LLM-based layout generation
ENABLE_LLM=true
# Enable debug mode (verbose logging, relaxed validation)
DEBUG_MODE=false
# Enable performance monitoring
ENABLE_METRICS=true

# Development Configuration
# Enable hot reload during development
HOT_RELOAD=true
# Auto-reconnect WebSocket on disconnect
WS_AUTO_RECONNECT=true
# WebSocket reconnection interval in milliseconds
WS_RECONNECT_INTERVAL=3000
