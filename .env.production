# Production Environment Configuration
# Deploy with GitHub: git push origin main
# Server: 192.168.68.56
# Container uses --network host

# Discord Configuration (REQUIRED - set in deployment)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=

# LLM Service - Production server (same network)
LLM_SERVER_URL=http://192.168.68.62:1234
LLM_TIMEOUT_MS=5000
LLM_MAX_RETRIES=1
LLM_FALLBACK_ENABLED=true

# Backend - Production settings
BACKEND_HOST=0.0.0.0
BACKEND_WS_PORT=8080
AKKA_ACTOR_SYSTEM_NAME=DiscordVisualRoom
LOG_LEVEL=WARNING

# Frontend - Production build
FRONTEND_PORT=8000
FRONTEND_WS_URL=ws://localhost:8080

# Room - Full capacity
ROOM_MAX_USERS=20
ROOM_DIMENSIONS_WIDTH=50
ROOM_DIMENSIONS_HEIGHT=10
ROOM_DIMENSIONS_DEPTH=50

# Features - Optimized for production
ENABLE_LLM=true
DEBUG_MODE=false
ENABLE_METRICS=true

# Production stability
HOT_RELOAD=false
WS_AUTO_RECONNECT=true
WS_RECONNECT_INTERVAL=3000
