# ========================================================================
# Discord Visual Room - Environment Configuration Template
# ========================================================================
#
# Copy this file to .env and configure with your actual values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your configuration
#   docker compose -f docker/docker-compose.yml up -d
#
# ========================================================================

# ========================================================================
# LLM Server Configuration
# ------------------------------------------------------------------------
# The LLM server runs on the Windows PC at 192.168.68.62:1234
# This is the llama.cpp server for furniture layout generation
# ========================================================================
LLM_SERVER_URL=http://192.168.68.62:1234
LLM_TIMEOUT=30000
LLM_MAX_RETRIES=3

# ========================================================================
# Discord Bot Configuration
# ------------------------------------------------------------------------
# Get your bot token from: https://discord.com/developers/applications
# Required features:
# - Voice connection permissions
# - Read user activity (for game detection)
# ========================================================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ========================================================================
# Backend WebSocket Configuration
# ------------------------------------------------------------------------
# Port for WebSocket connections from frontend
# Uses host network mode, so this is directly on the host
# ========================================================================
WS_PORT=8080
WS_HOST=0.0.0.0

# ========================================================================
# Frontend Configuration
# ------------------------------------------------------------------------
# VITE_API_URL is the WebSocket URL for the frontend to connect to backend
# In production (host network), use localhost:PORT
# ========================================================================
VITE_API_URL=ws://localhost:8080

# ========================================================================
# Room Configuration
# ------------------------------------------------------------------------
# Default room settings for the visual room
# These can be overridden per deployment
# ========================================================================
ROOM_ID=default-room
ROOM_NAME=Discord Visual Room
ROOM_MAX_USERS=10
ROOM_WIDTH=10
ROOM_HEIGHT=3
ROOM_DEPTH=10

# ========================================================================
# JVM Configuration
# ------------------------------------------------------------------------
# Java Virtual Machine options for the backend
# Adjust based on available memory and performance requirements
# ========================================================================
JVM_OPTS=-Xmx512m -Xms128m -XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:+UseG1GC

# ========================================================================
# Logging Configuration
# ------------------------------------------------------------------------
# Log level for the backend application
# Options: DEBUG, INFO, WARN, ERROR
# ========================================================================
LOG_LEVEL=INFO

# ========================================================================
# Development Mode Configuration
# ------------------------------------------------------------------------
# These settings are only used in docker-compose.dev.yml
# ========================================================================
# VITE_PORT=8000
# VITE_HOST=0.0.0.0

